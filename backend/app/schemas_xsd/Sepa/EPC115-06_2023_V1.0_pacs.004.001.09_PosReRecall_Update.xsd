  <xs:simpleType name="IBAN2007Identifier">
    <xs:annotation>
      <xs:documentation xml:lang="EN" source="Name">IBAN2007Identifier</xs:documentation>
      <xs:documentation xml:lang="EN" source="Definition">The International Bank Account Number is a code used internationally by financial institutions to uniquely identify the account of a customer at a financial institution as described in the 2007 edition of the ISO 13616 standard "Banking and related financial services - International Bank Account Number (IBAN)" and replaced by the more recent edition of the standard.</xs:documentation>
